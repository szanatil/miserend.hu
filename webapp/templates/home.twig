                <script>
                    (function($){
                        function updateLanguageHiddenInputs() {
                            var shouldArr = [];
                            var shouldNotArr = [];
                            $('.lang-toggle').each(function(){
                                var state = Number($(this).data('state')) || 0;
                                var lang = $(this).data('lang');
                                if (state === 1) shouldArr.push(lang);
                                else if (state === 2) shouldNotArr.push(lang);
                            });
                            $('#lang_should').val(shouldArr.join(','));
                            $('#lang_must_not').val(shouldNotArr.join(','));
                        }

                        function applyLanguageState($btn, state) {
                            // state: 0 neutral, 1 success (green), 2 danger (red)
                            $btn.data('state', state);
                            $btn.removeClass('btn-light btn-success btn-danger');
                            if (state === 0) {
                                $btn.addClass('btn-light');
                            } else if (state === 1) {
                                $btn.addClass('btn-success');
                            } else if (state === 2) {
                                $btn.addClass('btn-danger');
                            }
                        }

                        $(function(){
                            // Initialize: hu is green by default, others neutral
                            $('.lang-toggle').each(function(){
                                var lang = $(this).data('lang');
                                if (lang === 'hu') {
                                    applyLanguageState($(this), 1);
                                } else {
                                    applyLanguageState($(this), 0);
                                }
                            });

                            // Click handler: cycle through states 0 -> 1 -> 2 -> 0
                            $(document).on('click', '.lang-toggle', function(e){
                                e.preventDefault();
                                var $btn = $(this);
                                var state = Number($btn.data('state')) || 0;
                                var next = (state + 1) % 3;
                                applyLanguageState($btn, next);
                                updateLanguageHiddenInputs();
                            });

                            // Update on init
                            updateLanguageHiddenInputs();
                        });
                    })(jQuery);
                </script>
              
                {# Button group for types: cycles neutral -> success -> danger -> neutral #}
                <div class="form-group row">
                    <label class="col-sm-4 control-label">Típusok</label>
                    <div class="col-sm-8">
                        <div class="btn-group" role="group" aria-label="Type filters" id="type_Roman_catholic_Group">                            
