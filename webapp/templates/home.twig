                        </div>

                        {# third group: TRADITIONAL + SINGER and SILENT #}
                        <div class="btn-group mt-2" role="group" aria-label="Type filters 3"  id="type_Traditional_Group">
                            {{ macros.type_button('TRADITIONAL',true) }}
                            {{ macros.type_button('SINGER') }}
                            {{ macros.type_button('SILENT') }}
                        </div>

                        <div style="margin-top:6px; font-size:0.9em; color:#666">Kattints a gombra: zöld = legyen (should), piros = kizárt (must_not)</div>
                        
                        {# Per-special hidden flags: .should (green) and .must_not (red) Comma-separated lists. #}
                        <input type="hidden" name="types[ROMAN_CATHOLIC][should]" id="types_ROMAN_CATHOLIC_should" value="">
                        <input type="hidden" name="types[ROMAN_CATHOLIC][must_not]" id="types_ROMAN_CATHOLIC_must_not" value="">

                        <input type="hidden" name="types[GREEK_CATHOLIC][should]" id="types_GREEK_CATHOLIC_should" value="">
                        <input type="hidden" name="types[GREEK_CATHOLIC][must_not]" id="types_GREEK_CATHOLIC_must_not" value="">

                        <input type="hidden" name="types[TRADITIONAL][should]" id="types_TRADITIONAL_should" value="">
                        <input type="hidden" name="types[TRADITIONAL][must_not]" id="types_TRADITIONAL_must_not" value="">

                        {# Aggregate rites inputs: which rites are 'should' (green) and 'must_not' (red) #}
                        <input type="hidden" name="rites[should]" id="rites_should" value="">
                        <input type="hidden" name="rites[must_not]" id="rites_must_not" value="">
                    </div>
                </div>

                <script>
                    (function($){
                        function updateHiddenInputs() {
                            
                            // update aggregated rites inputs based on special buttons
                            var ritesShould = [];
                            var ritesMustNot = [];
                            $('.special-toggle').each(function(){
                                var s = Number($(this).data('state')) || 0;
                                var t = $(this).data('type');
                                if (s === 1) ritesShould.push(t);
                                else if (s === 2) ritesMustNot.push(t);
                            });
                            $('#rites_should').val(ritesShould.join(','));
                            $('#rites_must_not').val(ritesMustNot.join(','));
                            
                            // ROMAN_CATHOLIC: include the special itself (if green/red) and also                            
                            var romanShouldArr = [];
                            var romanMustNotArr = [];
                            $('#type_Roman_catholic_Group .type-toggle').not('.special-toggle').each(function(){
                                var s = Number($(this).data('state')) || 0;
                                var t = $(this).data('type');
                                if (s === 1) romanShouldArr.push(t);
                                else if (s === 2) romanMustNotArr.push(t);
                            });
                            $('#types_ROMAN_CATHOLIC_should').val(romanShouldArr.join(','));
                            $('#types_ROMAN_CATHOLIC_must_not').val(romanMustNotArr.join(','));

                            // GREEK_CATHOLIC: include the special itself (if green/red) and also
                            var greekShouldArr = [];
                            var greekMustNotArr = [];
                            $('#type_Greek_catholic_Group .type-toggle').not('.special-toggle').each(function(){
                                var s = Number($(this).data('state')) || 0;
                                var t = $(this).data('type');
                                if (s === 1) greekShouldArr.push(t);
                                else if (s === 2) greekMustNotArr.push(t);
                            });
                            $('#types_GREEK_CATHOLIC_should').val(greekShouldArr.join(','));
                            $('#types_GREEK_CATHOLIC_must_not').val(greekMustNotArr.join(','));

                            // TRADITIONAL: include the special itself (if green/red) and also
                            var traditionalShouldArr = [];
                            var traditionalMustNotArr = [];
                            $('#type_Traditional_Group .type-toggle').not('.special-toggle').each(function(){
                                var s = Number($(this).data('state')) || 0;
                                var t = $(this).data('type');
                                if (s === 1) traditionalShouldArr.push(t);
                                else if (s === 2) traditionalMustNotArr.push(t);
                            });
                            $('#types_TRADITIONAL_should').val(traditionalShouldArr.join(','));
                            $('#types_TRADITIONAL_must_not').val(traditionalMustNotArr.join(','));
                        }

                        function applyState($btn, state) {
                            // state: 0 neutral, 1 success, 2 danger
                            // For special buttons, force only 1 or 2 (no neutral)
                            if ($btn.hasClass('special-toggle') && state === 0) {
                                state = 1;
                            }
                            $btn.data('state', state);
                            $btn.prop('disabled', false);
                            $btn.removeClass('btn-light btn-success btn-danger');
                            if (state === 0) {
                                $btn.addClass('btn-light');
                            } else if (state === 1) {
                                $btn.addClass('btn-success');
                            } else if (state === 2) {
                                $btn.addClass('btn-danger');
                            }
                        }

                        // Update only the special button's own group when its state changes.
                        function updateSpecialGroup($special) {
                            var state = Number($special.data('state')) || 0;
                            var $group = $special.closest('.btn-group');
                            if (state === 2) {
                                // mark group invalid: disable other buttons in this same group
                                $group.addClass('invalid-row');
                                $group.find('.type-toggle').not($special).each(function(){
                                    $(this).prop('disabled', true);
                                    $(this).addClass('disabled');
                                });
                            } else {
                                // valid: enable other buttons in this group
                                $group.removeClass('invalid-row');
                                $group.find('.type-toggle').not($special).each(function(){
                                    $(this).prop('disabled', false);
                                    $(this).removeClass('disabled');
                                });
                            }
                        }
 
                        $(function(){
                            // initialize from any existing hidden inputs (e.g., preserved values)
                            var initMust = ($('#types_must').val() || '').toString().split(',').filter(Boolean);
                            var initMustNot = ($('#types_must_not').val() || '').toString().split(',').filter(Boolean);
                            $('.type-toggle').each(function(){
                                var $btn = $(this);
                                var type = $btn.data('type');
                                if (initMust.indexOf(type) !== -1) applyState($btn, 1);
                                else if (initMustNot.indexOf(type) !== -1) applyState($btn, 2);
                                else {
                                    // If no hidden inputs provided, default special buttons to green, others neutral
                                    if ($btn.hasClass('special-toggle')) {
                                        applyState($btn, 1);
                                    } else {
                                        applyState($btn, 0);
                                    }
                                }
                            });

                            // Ensure specials never remain neutral: convert any special with state 0 to 1
                            $('.special-toggle').each(function(){
                                var $s = $(this);
                                if (Number($s.data('state')) === 0) {
                                    applyState($s, 1);
                                }
                                updateSpecialGroup($s);
                            });

                            // click behavior
                            $(document).on('click', '.type-toggle', function(e){
                                // prevent clicks on disabled buttons
                                if ($(this).prop('disabled')) return;
                                e.preventDefault();
                                var $btn = $(this);
                                var state = Number($btn.data('state')) || 0;

                                if ($btn.hasClass('special-toggle')) {
                                    // toggle between green (1) and red (2) only
                                    var next = (state === 1) ? 2 : 1;
                                    applyState($btn, next);
                                    updateSpecialGroup($btn);
                                } else {
                                    // regular buttons cycle: 0 -> 1 -> 2 -> 0
                                    var next = (state + 1) % 3;
                                    applyState($btn, next);
                                }

                                updateHiddenInputs();
                            });

                            // update hidden inputs on init
                            updateHiddenInputs();
                        });
                    })(jQuery);
                </script>


            </div>

            <div align=center class="form-group" style="margin-top:12px">
                <button type=submit name="q" value="SearchResultsMasses"  class="btn btn-primary">Mise keresése</button>
                <button type=submit name="q" value="SearchResultsChurches"  class="btn btn-primary">Templom keresése</button>
            </div>

        </form>
    </div>
	
