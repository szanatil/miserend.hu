{# Macro to render a type-toggle button. Usage: {{ macros.type_button('FAMILY', 'Family') }} #}
{% macro type_button(type, special=false) %}
    <button type="button" class="btn btn-outline-secondary type-toggle{% if special %} special-toggle{% endif %}" data-type="{{ type }}" data-state="0"{% if special %} data-special="true"{% endif %}>
        {% if not special %}
            <img src="/cal_images/types/{{ type|lower }}.png" title="{{ type|trans }}" alt="{{ type|trans }}" style="height:1.3em; margin-right:6px; vertical-align:middle;">
        {% else %}            
            <img src="/cal_images/types/{{ type|lower }}.svg" title="{{ type|trans }}" alt="{{ type|trans }}" style="height:1.3em; margin-right:6px; vertical-align:middle;">
            {{ type|trans }}
        {% endif %}            
            
    </button>
{% endmacro %}

